# Copy to `.env` and fill in your key. `.env` is git-ignored.

# Your OpenAI API key (required). Needs credit; the full run makes ~600 calls.
OPENAI_API_KEY=sk-your-key-here

# Model used for all agent roles (solvers, judge) and for LLM-as-judge grading.
OPENAI_MODEL=gpt-5-mini

# Optional: max structured-output retries in the LLM client.
MAX_RETRIES=2

# Port for the local web app (web_app.py). README examples use 8000.
PORT=8000
